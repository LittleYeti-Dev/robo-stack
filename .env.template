# ============================================================================
# Robo Stack Environment Variables Template
# ============================================================================
# IMPORTANT: This is a template file. DO NOT use this as your .env file.
# 1. Copy this file: cp .env.template .env
# 2. Fill in the required values for your environment
# 3. NEVER commit .env to version control
# 4. Keep this template updated as new variables are added
# ============================================================================

# ============================================================================
# GENERAL CONFIGURATION
# ============================================================================

# Application environment: development, staging, production
NODE_ENV=development

# Application name and version
APP_NAME=robo-stack
APP_VERSION=1.0.0

# Application port
PORT=3000

# Application base URL (used for links, redirects, etc.)
APP_URL=http://localhost:3000

# Logging level: debug, info, warn, error
LOG_LEVEL=info

# ============================================================================
# DOCKER CONFIGURATION
# ============================================================================

# Docker registry (if using private registry)
DOCKER_REGISTRY=ghcr.io

# Docker image repository name
DOCKER_REPO=your-org/robo-stack

# Docker image tag (defaults to git commit SHA or 'latest')
DOCKER_TAG=latest

# ============================================================================
# KUBERNETES CONFIGURATION (for K8s deployments)
# ============================================================================

# Kubernetes namespace for deployment
K8S_NAMESPACE=robo-stack

# Kubernetes cluster name
K8S_CLUSTER=production

# Kubernetes context name
K8S_CONTEXT=your-cluster-context

# ============================================================================
# GITHUB CONFIGURATION
# ============================================================================

# GitHub personal access token (for API interactions)
# Scopes needed: repo, actions, read:org
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub repository owner
GITHUB_OWNER=your-org

# GitHub repository name
GITHUB_REPO=robo-stack

# GitHub webhook secret (for validating webhook signatures)
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# ============================================================================
# AWS CONFIGURATION (Future/Optional)
# ============================================================================

# AWS region for S3, CloudFormation, etc.
AWS_REGION=us-east-1

# AWS account ID
AWS_ACCOUNT_ID=123456789012

# AWS access key ID (prefer IAM roles in production)
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE

# AWS secret access key (prefer IAM roles in production)
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# S3 bucket for artifacts or backups
S3_BUCKET=robo-stack-artifacts

# ============================================================================
# SECURITY & SECRETS
# ============================================================================

# JWT secret for signing tokens (generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-here

# API key for external services
API_KEY=your-api-key-here

# Database password (use strong, random value)
DB_PASSWORD=your-secure-password-here

# ============================================================================
# DEVELOPMENT & DEBUGGING
# ============================================================================

# Enable debug mode (may expose sensitive info, use only in dev)
DEBUG=false

# Enable verbose logging
VERBOSE=false

# Timeout for long-running operations (milliseconds)
OPERATION_TIMEOUT=30000

# ============================================================================
# NOTES
# ============================================================================
# - Never commit .env files to version control
# - Use different .env files for different environments (dev, staging, prod)
# - Store secrets in secure vaults (GitHub Secrets, AWS Secrets Manager, etc.)
# - Rotate credentials regularly
# - Audit which environment variables are used in your code
# - Remove unused variables from this template
# ============================================================================
